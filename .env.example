# OrkaFin Local V1 configuration. Values are safe local examples only.
ORKAFIN_ENVIRONMENT=local
ORKAFIN_DATABASE_URL=sqlite:///./var/orkafin.db
ORKAFIN_LOG_LEVEL=INFO
ORKAFIN_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
ORKAFIN_CORS_ALLOW_CREDENTIALS=false
ORKAFIN_ACCEPT_INCOMING_REQUEST_IDS=true
ORKAFIN_AI_PROVIDER=deterministic
ORKAFIN_AI_PROVIDER_API_KEY=
ORKAFIN_CONFIRMATION_TTL_SECONDS=300
ORKAFIN_FIXTURE_MODE=true
# Synthetic local harness only; leave blank for fail-closed identity handling.
ORKAFIN_LOCAL_FIXTURE_SUBJECT=
ORKAFIN_DEBUG=false
